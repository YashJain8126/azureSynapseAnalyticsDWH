{
	"name": "transformationDataFlow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Parquet_Bronze",
						"type": "DatasetReference"
					},
					"name": "sourceBronze"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver",
						"type": "DatasetReference"
					},
					"name": "silverDestination"
				}
			],
			"transformations": [
				{
					"name": "addingDomainColumn"
				},
				{
					"name": "alterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderID as string,",
				"          OrderDate as date,",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          CustomerEmail as string,",
				"          ProductID as string,",
				"          ProductName as string,",
				"          ProductCategory as string,",
				"          RegionID as string,",
				"          RegionName as string,",
				"          Country as string,",
				"          Quantity as long,",
				"          UnitPrice as long,",
				"          TotalAmount as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> sourceBronze",
				"sourceBronze derive(Domain = split(CustomerEmail,'@')[2]) ~> addingDomainColumn",
				"addingDomainColumn alterRow(insertIf(1==1)) ~> alterRow",
				"alterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> silverDestination"
			]
		}
	}
}